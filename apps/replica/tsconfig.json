{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@scraw/shared": ["../../packages/shared"]
    }
  },
  "include": ["src/**/*", "../../packages/shared/**/*"]
}
